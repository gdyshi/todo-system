# 应用配置
APP_NAME="Todo System"
VERSION="1.0.0"
DEBUG=True

# 数据库
DATABASE_PATH=database/todo.db

# Telegram配置（用于提醒）
# 从@BotFather获取Bot Token
# Chat ID可以通过给@userinfobot发消息获取
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Render配置（用于后端部署）
# 从Render Dashboard -> Service -> Settings -> Deploy Hooks获取
RENDER_DEPLOY_HOOK=your_render_deploy_hook_here

# GitHub配置（用于自动审查和通知）
# Personal Access Token需要repo权限
GITHUB_USERNAME=your_github_username
GITHUB_REPO=your_repo_name
GITHUB_TOKEN=your_github_token

# AI 模型配置（用于子任务生成）
# 从 OspreyAI 获取 API Key
MODEL_URL=https://open.ospreyai.cn/v1/chat/completions
MODEL_NAME=minimax-m2.5-highspeed
MODEL_KEY=
